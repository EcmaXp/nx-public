#!/usr/bin/env -S just -f
# nx-os: NixOS/Darwin system management

export JUST_JUSTFILE := justfile()

# List all commands
default:
    @just --list

# Build system configuration
build *args:
    #!/usr/bin/env fish
    if test (uname) = "Linux"
        nh os build --no-nom {{args}}
    else
        nh darwin build --no-nom {{args}}
    end

# Switch to new system configuration
switch *args:
    #!/usr/bin/env fish
    if test (uname) = "Linux"
        nh os switch --no-nom {{args}}
    else
        nh darwin switch --no-nom {{args}}
    end

# Test system configuration
test *args:
    #!/usr/bin/env fish
    if test (uname) = "Linux"
        nh os test --no-nom {{args}}
    else
        nh darwin test --no-nom {{args}}
    end
